# .env.example — Copy to .env and fill in values before first run.
# NEVER commit .env to version control.

# Optional: set a unique Compose project name if you keep multiple local copies
# on the same machine (example: COMPOSE_PROJECT_NAME=otrap_jan_laptop).
# COMPOSE_PROJECT_NAME=otrap_local

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=otrap
POSTGRES_USER=otrap
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# ─── Redis ────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis auth in local/dev deployments.
REDIS_PASSWORD=

# ─── Manager Security ─────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_64_HEX_CHAR_RANDOM_STRING_HERE_xxxxxxxxxxxxxxxxxxxxxxx

# 32-char key for AES-256-GCM encryption of SMTP/SIEM secrets at rest
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_AES_KEY_HERE____

# Local single-host HTTP quick start uses false.
# Set to true behind HTTPS in production.
SESSION_SECURE=false

# ─── Initial Superadmin ───────────────────────────────────────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_12CHARS

# ─── gRPC / CA ────────────────────────────────────────────────────────────────
# Docker port binding for Manager gRPC. Leave empty — install_manager.sh sets
# this to 0.0.0.0 automatically so remote sensors can reach it.
GRPC_HOST=

# These are auto-generated on first run and printed to manager logs.
# The installer persists them automatically to survive manager restarts.
GRPC_CA_KEY_B64=
GRPC_CA_CERT_B64=
JOIN_TOKEN_TTL_HOURS=24

# ─── Sensor ───────────────────────────────────────────────────────────────────
# Set SENSOR_JOIN_TOKEN before first sensor start.
# Generate via: POST /api/v1/sensors/token (superadmin only)
SENSOR_JOIN_TOKEN=
SENSOR_NAME=sensor-01

# 64-char hex key for sensor cert encryption at rest
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SENSOR_CERT_ENC_KEY=CHANGE_ME_64_HEX_CHAR_SENSOR_CERT_KEY_HERE_xxxxxxxxxxxxxx

# Canonical manager gRPC address embedded in generated sensor deployment
# commands. Leave empty — install_manager.sh auto-detects the outbound LAN IP.
SENSOR_PUBLIC_MANAGER_ADDR=

# HTTP base URL for the sensor installer endpoint (curl install command).
# Leave empty — auto-derived from SENSOR_PUBLIC_MANAGER_ADDR.
INSTALLER_BASE_URL_OVERRIDE=

# Image used in the generated remote sensor Docker run command.
# IMPORTANT: ghcr.io/otrap/sensor:latest is a placeholder — this image is NOT
# published to a public registry. You must build and push it yourself first:
#   docker build -t <your-registry>/otrap-sensor:latest ./sensor
#   docker push <your-registry>/otrap-sensor:latest
# Then set SENSOR_IMAGE_REF to your registry path before generating sensor tokens.
SENSOR_IMAGE_REF=ghcr.io/otrap/sensor:latest

# Local single-host first join uses true because the Manager CA is generated at first start.
# After the sensor has joined and persisted its identity, set back to false if desired.
SENSOR_INSECURE_JOIN=true

# ─── Management Networking ────────────────────────────────────────────────────
# Leave empty — install_manager.sh sets these to 0.0.0.0 for remote access.
MANAGEMENT_HOST=
UI_HOST=

# Comma-separated allowed CORS origins for local browser access
CORS_ORIGINS=http://localhost:3000

# ─── UI ───────────────────────────────────────────────────────────────────────
# Browser-facing API URL. The UI now uses same-origin /api rewrites by default,
# but this origin is still used for CSP allowlisting and direct tooling.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Threat Intelligence (optional) ──────────────────────────────────────────
# GreyNoise Community API key — https://www.greynoise.io/
# Free tier: 1 000 IP checks / day. Leave blank to disable.
GREYNOISE_API_KEY=

# AbuseIPDB API key — https://www.abuseipdb.com/
# Free tier: 1 000 checks / day. Leave blank to disable.
ABUSEIPDB_API_KEY=

# ─── Local LLM Integration (Ollama / LM Studio) ───────────────────────────────
# Set LLM_ENABLED=true and configure your local LLM backend.
# OTrap supports Ollama and LM Studio (OpenAI-compatible API).
LLM_ENABLED=false

# Backend: "ollama" or "lmstudio"
LLM_BACKEND=ollama

# Ollama endpoint (default: http://localhost:11434)
# For Docker deployments use the host's LAN IP, e.g. http://192.168.1.100:11434
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio endpoint (default: http://localhost:1234)
LM_STUDIO_BASE_URL=http://localhost:1234

# Default model to pre-select in the UI (must be pulled in Ollama or loaded in LM Studio)
# Recommended: llama3.2, mistral:7b, gemma2:9b, deepseek-r1:8b
LLM_DEFAULT_MODEL=llama3.2

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
DOCS_ENABLED=false
